        "textColor": "#9a9994",
        "fontFamily": "unknown",
        "align": "left"
      },
      "frameId": "f-2",
      "visualKind": "text",
      "title": "<p>What pain point are we addressing?</p><p>What evidence proves this is a problem worth solving?</p><p>How does this problem impact our business goals?</p><p>Why is this a priority for us right now?</p>"
    },

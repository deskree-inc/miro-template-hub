    {
      "id": "n-25",
      "position": {
        "x": -7361.566501483464,
        "y": 434.78973063845905
      },
      "size": {
        "width": 686.6568482335693,
        "height": 968.1861560093326
      },
      "style": {
        "fillColor": "#F5F5F5",
        "borderColor": "#CCCCCC",

    {
      "id": "n-9",
      "position": {
        "x": 5056.820332554838,
        "y": 4982.535508475973
      },
      "size": {
        "width": 784.0,
        "height": 1836.0
      },
      "style": {
        "fillColor": "#F5F5F5",
